{
  "expo": {
    "name": "FitPro",
    "slug": "fitpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fitpro",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitpro.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f14",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.fitpro.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "O FitPro precisa da câmera para gravar vídeos dos exercícios."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O FitPro acessa sua galeria para selecionar fotos e vídeos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "02ec901a-c887-41d0-ab3f-598699d0ca12"
      }
    },
    "owner": "behrends312"
  }
}
